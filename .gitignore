bin/
# Rust crate `src/bin/` directories are NOT build output — they hold extra
# binary entrypoints for the same crate. Negate the `bin/` rule for them.
!bridge/*/src/bin/
!bridge/*/src/bin/**
!sdk/*/src/bin/
!sdk/*/src/bin/**
!watchers/*/src/bin/
!watchers/*/src/bin/**
obj/
out/
*.user
*.suo
.vs/
.vscode/
.idea/
node_modules/
dist/
target/
artifacts/
*.dll
*.pdb
*.exe
TestResults/
coverage/
*.coverage
*.lock
# Cargo.lock IS checked in for binary/cdylib crates so the bridge's transitive
# dep tree (esp. SP1 / neo-zkvm) is reproducible across `cargo build` runs.
!Cargo.lock
.DS_Store
*.swp
*.tmp
*.log
# mdBook generated static site (CI builds + deploys; not checked in).
book/

# Manuscript build artifacts (tools/manuscript/build.sh)
build/

# Local Codex audit scratch. Curated audit documents live under docs/audit/;
# raw logs, inventories, TRX files, and transient command outputs stay local.
CODEX_DEEP_AUDIT/
