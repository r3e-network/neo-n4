flowchart TB
    N1["1. neo-execution-core: State model explains what is remembered, committed, verified, or discarded."]
    N2["2. Input state: L2 batch | previous state root | execution parameters"]
    N3["3. Working state: validated input, working state, candidate output"]
    N4["4. Persistent state: accepted output and audit record"]
    N5["5. Transition: explicit rules turn accepted input into checkable output"]
    N6["6. Commitment: input digest, transition digest, and output digest"]
    N7["7. Finality: consumer accepts the output"]
    N8["8. Rollback or reject: reject output and retain diagnostics"]
    N1 --> N2
    N1 --> N3
    N1 --> N4
    N1 --> N5
    N1 --> N6
    N1 --> N7
    N1 --> N8
    N2 -. constrains .-> N4
    N4 -. produces .-> N5
    N5 -. consumed by .-> N6
    classDef core fill:#0f172a,stroke:#38bdf8,color:#e5f2ff,stroke-width:2px;
    classDef support fill:#111827,stroke:#64748b,color:#f8fafc;
    class N1 core;
    class N2,N3,N4,N5,N6,N7,N8 support;
