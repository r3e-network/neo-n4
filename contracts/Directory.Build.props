<Project>

  <!--
    Smart-contract projects type-check against Neo.SmartContract.Framework via
    dotnet build. Deployable .nef / .manifest.json artifacts are generated by
    running nccs explicitly in CI and operator deployment rehearsals.
  -->

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <OutputType>Library</OutputType>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!--
      Path to neo-project/neo-devpack-dotnet. Default points at the
      external/neo-devpack-dotnet git submodule (never released on NuGet,
      same shape as Neo 4 core). Override with `dotnet build /p:NeoDevpackPath=...`
      to point at a local fork.
    -->
    <NeoDevpackPath>$(MSBuildThisFileDirectory)..$([System.IO.Path]::DirectorySeparatorChar)external$([System.IO.Path]::DirectorySeparatorChar)neo-devpack-dotnet$([System.IO.Path]::DirectorySeparatorChar)src</NeoDevpackPath>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <NuGetAudit>false</NuGetAudit>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(NeoDevpackPath)\Neo.SmartContract.Framework\Neo.SmartContract.Framework.csproj" />
  </ItemGroup>

</Project>
