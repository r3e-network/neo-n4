flowchart TB
    N1["1. Entry domain: developer app | gateway endpoint | wallet/config"]
    N2["2. Normalization: shape commands, config, and files into typed operations"]
    N3["3. Core mechanism: Encode API requests | Handle bridge/proof models | Return typed results"]
    N4["4. State and commitment: request digest, network profile, and output artifact hash"]
    N5["5. Evidence or result: typed client result | transaction request | query response"]
    N6["6. Consumer boundary: apps | operators | integration tests"]
    N7["7. Failure path: invalid config, signing-policy failure, network rejection, or output validation failure"]
    N8["8. Extension point: commands, templates, network profiles, and output formats"]
    N1 --> N2
    N1 --> N3
    N1 --> N4
    N1 --> N5
    N1 --> N6
    N1 --> N7
    N1 --> N8
    N2 -. constrains .-> N4
    N4 -. produces .-> N5
    N5 -. consumed by .-> N6
    classDef core fill:#0f172a,stroke:#38bdf8,color:#e5f2ff,stroke-width:2px;
    classDef support fill:#111827,stroke:#64748b,color:#f8fafc;
    class N1 core;
    class N2,N3,N4,N5,N6,N7,N8 support;
