<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Neo.Stack.Cli</RootNamespace>
    <AssemblyName>neo-stack</AssemblyName>
    <Description>Launch framework CLI for Neo Elastic Network L2 chains.</Description>
    <PackageTags>NEO;L2;CLI;NeoStack</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(NeoCorePath)\Neo\Neo.csproj" />
    <ProjectReference Include="..\..\src\Neo.L2.Abstractions\Neo.L2.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\Neo.L2.Batch\Neo.L2.Batch.csproj" />
    <ProjectReference Include="..\..\src\Neo.L2.Executor\Neo.L2.Executor.csproj" />
    <ProjectReference Include="..\..\src\Neo.L2.Persistence\Neo.L2.Persistence.csproj" />
    <ProjectReference Include="..\..\src\Neo.L2.Settlement.Rpc\Neo.L2.Settlement.Rpc.csproj" />
    <ProjectReference Include="..\..\src\Neo.L2.Sequencer\Neo.L2.Sequencer.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Neo.Stack.Cli.UnitTests" />
  </ItemGroup>

</Project>
